# Robinhood Chain testnet
RPC_URL=https://rpc.testnet.chain.robinhood.com
CHAIN_ID=46630

# Deployed contract addresses (output of `forge script Deploy.s.sol ...`)
MANDATE_REGISTRY=0x...
MANAGED_VAULT=0x...
COMPLIANCE_PROVIDER=0x...

# Agent wallet private key (testnet only)
AGENT_PRIVATE_KEY=0x...

# Principal address (for reads/views)
PRINCIPAL_ADDRESS=0x...
AGENT_ID=1

# LLM (Groq is free)
LLM_PROVIDER=groq
GROQ_API_KEY=gsk_...

# Server port
PORT=3002
