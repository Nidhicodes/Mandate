# Robinhood Chain testnet RPC (public endpoint, no API key needed).
ROBINHOOD_TESTNET_RPC=https://rpc.testnet.chain.robinhood.com

# Deployer key (testnet only — never a mainnet key). Funds gas + acts as admin/compliance officer.
DEPLOYER_PK=0x...

# Agent wallet the AI manager uses to instruct the vault.
AGENT_WALLET=0x...

# Optional: distinct regulator address that holds the REGULATORY kill-switch role.
# MUST differ from the deployer/admin (self-escalation guard).
REGULATOR_ADDRESS=0x...

# Agent id for the demo mandate.
AGENT_ID=1
